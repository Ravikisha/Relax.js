{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "emitDeclarationOnly": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": false,
    "outDir": "./dist-types"
  },
  "include": [
    "src/**/*",
    "runtime/**/*",
    "compiler/**/*",
    "relax-jsx/**/*"
  ]
}
