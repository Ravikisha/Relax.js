{
  "name": "relaxcore",
  "type": "module",
  "version": "1.0.1",
  "description": "A frontend framework to teach web developers how frontend frameworks work.",
  "keywords": [
    "frontend",
    "framework",
    "learning",
    "web",
    "development"
  ],
  "exports": {
    ".": {
      "types": "./dist-types/src/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.cjs"
    },
    "./ssg": {
      "types": "./dist-types/src/ssg/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.cjs"
    },
    "./hrbr": {
      "types": "./dist-types/runtime/index.d.ts",
      "import": "./dist/esm/hrbr.js",
      "require": "./dist/cjs/hrbr.cjs"
    },
    "./compiler": {
      "types": "./dist-types/compiler/index.d.ts",
      "import": "./dist/esm/compiler.js",
      "require": "./dist/cjs/compiler.cjs"
    }
  },
  "bin": {
    "relax-ssg": "./dist/esm/ssg-cli.js"
  },
  "main": "dist/cjs/index.cjs",
  "module": "dist/esm/index.js",
  "types": "dist-types/src/index.d.ts",
  "files": [
    "dist/",
    "dist-types/"
  ],
  "homepage": "",
  "bugs": {
    "url": "https://github.com/ravikisha/Relax.js/issues"
  },
  "scripts": {
  "build": "rollup -c && rollup -c rollup.config.cjs.mjs",
  "build:types": "tsc -p tsconfig.build-types.json",
  "build:book": "pdflatex -interaction=nonstopmode -halt-on-error -jobname=\"Relax.js Book\" book/main.tex && pdflatex -interaction=nonstopmode -halt-on-error -jobname=\"Relax.js Book\" book/main.tex && rm -f \"Relax.js Book.aux\" \"Relax.js Book.log\" \"Relax.js Book.out\" \"Relax.js Book.toc\"",
  "build:bench": "rollup -c rollup.benchmarks.config.mjs",
  "build:bench:dev": "NODE_ENV=development rollup -c rollup.benchmarks.config.mjs",
  "build:bench:prod": "NODE_ENV=production rollup -c rollup.benchmarks.config.mjs",
  "build:bench:smoke": "NODE_ENV=production rollup -c rollup.benchmarks.smoke.config.mjs",
  "serve:bench:smoke": "npm run -s build:bench:smoke && npx --yes http-server -p 4174 -c-1 benchmarks -o /perf-smoke.html",
    "serve:bench": "npm run -s build:bench && npx --yes http-server -p 4173 -c-1 .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage",
    "prepack": "npm run build && npm run build:types"
  },
  "author": "Ravi Kishan",
  "license": "MIT",
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/helper-plugin-utils": "^7.28.6",
    "@babel/plugin-syntax-jsx": "^7.28.6",
    "@babel/plugin-transform-modules-commonjs": "^7.28.6",
    "@rollup/plugin-commonjs": "^28.0.2",
    "@rollup/plugin-node-resolve": "^16.0.0",
    "@rollup/plugin-replace": "^6.0.3",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^11.1.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
  "@types/node": "^22.13.5",
    "@vitest/coverage-v8": "^2.1.8",
    "eslint": "^9.17.0",
    "jsdom": "^25.0.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "rollup": "^4.29.1",
    "rollup-plugin-cleanup": "^3.2.1",
    "rollup-plugin-filesize": "^10.0.0",
    "solid-js": "^1.9.11",
    "tslib": "^2.8.1",
    "typescript": "^5.7.3",
    "vitest": "^2.0.3"
  },
  "dependencies": {
  "fast-deep-equal": "^3.1.3",
  "marked": "^15.0.7"
  }
}
